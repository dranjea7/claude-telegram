# Copie ce fichier en .env et remplis les valeurs

# Token du bot Telegram (obtenu via @BotFather)
TELEGRAM_TOKEN=123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ton Telegram user ID (envoie /id au bot pour le trouver)
# Plusieurs IDs séparés par virgule : 123456,789012
ALLOWED_IDS=TON_TELEGRAM_ID

# Chemin vers le binaire claude (par défaut : claude dans le PATH)
CLAUDE_CMD=claude

# Répertoire de travail par défaut pour claude et les commandes /run
WORKDIR=/root
